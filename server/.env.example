# Copy to .env and set real values on the server
PORT=4000

# The single admin account (the login uses the email as the username)
ADMIN_USERNAME=you@example.com
ADMIN_PASSWORD=change-this-to-a-strong-password

# Secret used to sign login tokens (use a long random string)
JWT_SECRET=change-this-to-a-long-random-secret

# Public base URL where uploaded images are served from (leave blank for same-origin)
PUBLIC_URL=

# Note: the admin panel is served at a secret path on the site:
#   https://namastemandarin.com/nm-admin-9z3kq
# Avoid the '#' character in ADMIN_PASSWORD (env files treat it as a comment).
